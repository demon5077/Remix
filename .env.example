# ── JioSaavn API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://saavn.sumit.co/api/

# ── Muzo Backend API (YouTube Music, Similar, Stream, Trending, Charts, Moods)
# Default: https://Muzo-backend.vercel.app — or deploy your own instance
NEXT_PUBLIC_MUZO_API_URL=https://Muzo-backend.vercel.app

# ── YouTube (RapidAPI) — supports MULTIPLE keys, comma-separated ──────────────
# Get free keys at: https://rapidapi.com/yt-api/api/yt-api
# When one key hits rate limit, Arise auto-rotates to the next key
NEXT_PUBLIC_RAPIDAPI_KEY=key1,key2,key3

# ── Google OAuth (for YouTube playlist import) ────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Spotify OAuth (for Spotify playlist import) ───────────────────────────────
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Supabase (user DB) ────────────────────────────────────────────────────────
# Create free project at https://supabase.com
# Run the SQL schema from lib/supabase.js in the Supabase SQL editor
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # Project Settings → API → service_role key

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get free key at: https://resend.com (3000 emails/month free)
RESEND_API_KEY=re_your_resend_api_key
ARISE_FROM_EMAIL=Arise <noreply@yourdomain.com>

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── JioSaavn API (required) ─────────────────────────────────────────────────
# Hosted at https://saavn.sumit.co/api/ — no key needed, just the URL
NEXT_PUBLIC_API_URL=https://saavn.sumit.co/api/

# ── YouTube via RapidAPI (required for YouTube features) ─────────────────────
# 1. Sign up at https://rapidapi.com/ytjar/api/yt-api
# 2. Subscribe to the yt-api plan (free tier available)
# 3. Copy your RapidAPI key from the dashboard
NEXT_PUBLIC_RAPIDAPI_KEY=your_rapidapi_key_here

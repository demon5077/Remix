# ── Arise Environment Variables ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# ── JioSaavn API (required — no key needed) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://saavn.sumit.co/api/

# ── YouTube via RapidAPI (required for YouTube features) ─────────────────────
# Sign up at https://rapidapi.com/ytjar/api/yt-api (free tier available)
NEXT_PUBLIC_RAPIDAPI_KEY=your_rapidapi_key_here

# ── Google OAuth (for YouTube playlist import) ────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "YouTube Data API v3" + "Google+ API"
# 3. Credentials → Create OAuth 2.0 Client ID (Web Application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/auth/google/callback
#    (For production add: https://yourdomain.com/api/auth/google/callback)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Spotify OAuth (for Spotify playlist import) ───────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an App → Settings → Redirect URIs
# 3. Add: http://localhost:3000/api/auth/spotify/callback
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── App URL (used in OAuth redirects) ────────────────────────────────────────
# Set to your deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
